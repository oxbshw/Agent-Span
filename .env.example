## AgentSpan environment variables.
## Copy to .env and fill in the ones you need.

## --- Server ---
#AGENTSPAN_SERVER__HOST=0.0.0.0
#AGENTSPAN_SERVER__PORT=8080

## --- Cache ---
#AGENTSPAN_CACHE__L3_URL=redis://localhost:6379

## --- API keys for Tier-1 channels (all optional) ---
#OPENAI_API_KEY=sk-...
#ANTHROPIC_API_KEY=sk-ant-...
#BRAVE_API_KEY=...
#BING_API_KEY=...
#GOOGLE_API_KEY=...
#NOTION_API_KEY=...
#SLACK_API_KEY=...
#EXA_API_KEY=...
#JINA_API_KEY=...
#SPOTIFY_CLIENT_ID=...
#SPOTIFY_CLIENT_SECRET=...
#TWITCH_CLIENT_ID=...
#TWITCH_CLIENT_SECRET=...
#DISCORD_API_KEY=...
#TELEGRAM_API_KEY=...
#PODCASTINDEX_KEY=...
#PODCASTINDEX_SECRET=...
#SCHOLAR_API_KEY=...

## --- Channel backend overrides ---
#REDDIT_BACKEND=opencli
#TWITTER_BACKEND=twitter-cli
#BILIBILI_BACKEND=bili-cli

## --- Logging ---
#RUST_LOG=info
